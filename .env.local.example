# Copy this file to .env.local and fill in your keys
# .env.local is git-ignored and never committed

# api-sports.io (free 100 req/day — used as fallback)
FOOTBALL_API_KEY=your_api_sports_key_here

# football-data.org (free, WC 2026 data)
FOOTBALL_DATA_API_KEY=your_football_data_key_here

# RapidAPI key (free-api-live-football-data — live scores across 125+ leagues)
RAPIDAPI_KEY=your_rapidapi_key_here

# Bearer token required by the write endpoints (matches#update, goals#create,
# stats/upsert). If unset, those endpoints reject every request.
ADMIN_API_TOKEN=generate_a_long_random_token

# Error monitoring (optional — inert if unset)
SENTRY_DSN=

