<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <% meta = @meta || PageMeta.for(request.path) %>
  <% image_url = request.base_url + meta.image %>
  <title><%= meta.title %></title>
  <meta name="description" content="<%= meta.description %>">
  <link rel="canonical" href="<%= request.original_url %>">
  <meta name="theme-color" content="#ee1e46">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/images/icon-192.png">

  <%# Open Graph / Twitter — section-aware so shared links unfurl meaningfully %>
  <meta property="og:site_name" content="Golazo">
  <meta property="og:title" content="<%= meta.title %>">
  <meta property="og:description" content="<%= meta.description %>">
  <meta property="og:type" content="<%= meta.type %>">
  <meta property="og:url" content="<%= request.original_url %>">
  <meta property="og:image" content="<%= image_url %>">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= meta.title %>">
  <meta name="twitter:description" content="<%= meta.description %>">
  <meta name="twitter:image" content="<%= image_url %>">

  <%= csrf_meta_tags %>

  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;700;900&display=swap" rel="stylesheet">

  <%# Template vendor CSS — icomoon icons, flaticon, owl carousel, AOS %>
  <link rel="stylesheet" href="/fonts/icomoon/style.css">
  <link rel="stylesheet" href="/fonts/flaticon/font/flaticon.css">
  <link rel="stylesheet" href="/owl.carousel.min.css">
  <link rel="stylesheet" href="/owl.theme.default.min.css">
  <link rel="stylesheet" href="/aos.css">

  <%# Vite: React + Bootstrap + template CSS (all from application.css) %>
  <% if ViteRuby.instance.dev_server_running? %>
    <%= vite_client_tag %>
    <%= vite_react_refresh_tag %>
  <% end %>
  <%= vite_javascript_tag "application.jsx" %>
</head>
<body>

  <div id="root"></div>

  <%# jQuery must load synchronously so it is available when main.js runs %>
  <script src="/jquery-3.3.1.min.js"></script>
  <script src="/bootstrap.min.js"></script>
  <script src="/owl.carousel.min.js"></script>
  <script src="/jquery.countdown.min.js"></script>
  <script src="/jquery.easing.1.3.js"></script>
  <script src="/aos.js"></script>
  <script src="/jquery.fancybox.min.js"></script>
  <script src="/jquery.stellar.min.js"></script>
  <script src="/jquery.sticky.js"></script>

  <%# main.js deferred so it runs after React mounts the DOM %>
  <script src="/main.js" defer></script>

</body>
</html>
