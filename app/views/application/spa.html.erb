<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no, viewport-fit=cover">
  <% meta = @meta || PageMeta.for(request.path) %>
  <% image_url = request.base_url + meta.image %>
  <title><%= meta.title %></title>
  <meta name="description" content="<%= meta.description %>">
  <link rel="canonical" href="<%= request.original_url %>">
  <meta name="theme-color" content="#ee1e46">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png?v=2">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Golazo">

  <%# iOS splash screens — eliminates white/gray flash on PWA launch %>
  <link rel="apple-touch-startup-image" media="(device-width: 320px) and (device-height: 568px) and (-webkit-device-pixel-ratio: 2)" href="/images/splash/apple-splash-iphone-se.png">
  <link rel="apple-touch-startup-image" media="(device-width: 375px) and (device-height: 667px) and (-webkit-device-pixel-ratio: 2)" href="/images/splash/apple-splash-iphone-8.png">
  <link rel="apple-touch-startup-image" media="(device-width: 414px) and (device-height: 736px) and (-webkit-device-pixel-ratio: 3)" href="/images/splash/apple-splash-iphone-8-plus.png">
  <link rel="apple-touch-startup-image" media="(device-width: 375px) and (device-height: 812px) and (-webkit-device-pixel-ratio: 3)" href="/images/splash/apple-splash-iphone-x.png">
  <link rel="apple-touch-startup-image" media="(device-width: 414px) and (device-height: 896px) and (-webkit-device-pixel-ratio: 2)" href="/images/splash/apple-splash-iphone-xr.png">
  <link rel="apple-touch-startup-image" media="(device-width: 414px) and (device-height: 896px) and (-webkit-device-pixel-ratio: 3)" href="/images/splash/apple-splash-iphone-xs-max.png">
  <link rel="apple-touch-startup-image" media="(device-width: 375px) and (device-height: 812px) and (-webkit-device-pixel-ratio: 3) and (display-mode: standalone)" href="/images/splash/apple-splash-iphone-12-mini.png">
  <link rel="apple-touch-startup-image" media="(device-width: 390px) and (device-height: 844px) and (-webkit-device-pixel-ratio: 3)" href="/images/splash/apple-splash-iphone-12.png">
  <link rel="apple-touch-startup-image" media="(device-width: 428px) and (device-height: 926px) and (-webkit-device-pixel-ratio: 3)" href="/images/splash/apple-splash-iphone-12-pro-max.png">
  <link rel="apple-touch-startup-image" media="(device-width: 393px) and (device-height: 852px) and (-webkit-device-pixel-ratio: 3)" href="/images/splash/apple-splash-iphone-15-pro.png">
  <link rel="apple-touch-startup-image" media="(device-width: 430px) and (device-height: 932px) and (-webkit-device-pixel-ratio: 3)" href="/images/splash/apple-splash-iphone-15-pro-max.png">

  <%# Open Graph / Twitter — section-aware so shared links unfurl meaningfully %>
  <meta property="og:site_name" content="Golazo">
  <meta property="og:title" content="<%= meta.title %>">
  <meta property="og:description" content="<%= meta.description %>">
  <meta property="og:type" content="<%= meta.type %>">
  <meta property="og:url" content="<%= request.original_url %>">
  <meta property="og:image" content="<%= image_url %>">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= meta.title %>">
  <meta name="twitter:description" content="<%= meta.description %>">
  <meta name="twitter:image" content="<%= image_url %>">

  <%= csrf_meta_tags %>

  <%# JSON-LD structured data for entity pages (match, team) %>
  <% if meta.json_ld.present? %>
    <script type="application/ld+json"><%= raw meta.json_ld.to_json %></script>
  <% end %>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://flagcdn.com" crossorigin>
  <link rel="preconnect" href="https://media.api-sports.io" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;700;900&display=swap" rel="stylesheet">


  <%# Vite: React + Bootstrap + template CSS (all from application.css) %>
  <% if ViteRuby.instance.dev_server_running? %>
    <%= vite_client_tag %>
    <%= vite_react_refresh_tag %>
  <% end %>
  <%= vite_javascript_tag "application.jsx" %>
</head>
<body>

  <div id="root"></div>


</body>
</html>
