<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:news="http://www.google.com/schemas/sitemap-news/0.9"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1">

  <%# Static section pages %>
  <% @static_urls.each do |path| %>
  <url>
    <loc><%= @base %><%= path %></loc>
    <changefreq><%= path.include?("live") || path.include?("today") ? "always" : "daily" %></changefreq>
    <priority><%= path == "/" ? "1.0" : "0.8" %></priority>
  </url>
  <% end %>

  <%# Dynamic match pages %>
  <% @matches.each do |match| %>
  <url>
    <loc><%= @base %>/matches/<%= match.id %></loc>
    <lastmod><%= (match.updated_at || match.kickoff_at)&.strftime("%Y-%m-%d") %></lastmod>
    <changefreq><%= match.status == "live" ? "always" : match.status == "scheduled" ? "daily" : "monthly" %></changefreq>
    <priority>0.7</priority>
  </url>
  <% end %>

  <%# Dynamic team pages %>
  <% @teams.each do |team| %>
  <url>
    <loc><%= @base %>/teams/<%= team.id %></loc>
    <changefreq>daily</changefreq>
    <priority>0.6</priority>
  </url>
  <% end %>

  <%# League detail pages %>
  <% @league_codes.each do |code| %>
  <url>
    <loc><%= @base %>/leagues/<%= CGI.escape(code) %></loc>
    <changefreq>daily</changefreq>
    <priority>0.6</priority>
  </url>
  <% end %>

  <%# News article pages %>
  <% @news_articles.each do |article| %>
  <url>
    <loc><%= @base %>/news/<%= article[:id] %></loc>
    <lastmod><%= article[:published_at]&.strftime("%Y-%m-%d") %></lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
    <% if article[:title].present? %>
    <news:news>
      <news:publication>
        <news:name>Golazo</news:name>
        <news:language>en</news:language>
      </news:publication>
      <news:publication_date><%= article[:published_at]&.iso8601 %></news:publication_date>
      <news:title><%= CGI.escapeHTML(article[:title].to_s) %></news:title>
    </news:news>
    <% end %>
  </url>
  <% end %>

</urlset>
