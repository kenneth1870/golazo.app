#!/usr/bin/env bash
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "🔍 Running RuboCop..."
if ! bin/rubocop --no-color; then
  echo ""
  echo "❌ RuboCop failed. Run 'bin/rubocop --autocorrect' to fix, then push again."
  exit 1
fi

echo ""
echo "🧪 Running unit tests..."
if ! PARALLEL_WORKERS=1 RAILS_ENV=test bin/rails test; then
  echo ""
  echo "❌ Tests failed. Fix failing tests before pushing."
  exit 1
fi

echo ""
echo "✅ All checks passed — pushing."
